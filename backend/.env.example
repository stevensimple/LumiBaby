# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# SQLite (local dev) or PostgreSQL (production)
DATABASE_URL=sqlite+aiosqlite:///./babyvision.db
# DATABASE_URL=postgresql+asyncpg://babyvision:yourpassword@localhost:5432/babyvision

ENABLE_AUTH=true
JWT_EXPIRE_HOURS=24
CORS_ORIGINS=*
HOST=0.0.0.0
PORT=8000
INACTIVITY_ALERT_MINUTES=20
